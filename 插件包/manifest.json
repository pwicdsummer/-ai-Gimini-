{
  "manifest_version": 3,
  "name": "AI Record Master",
  "version": "1.0",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*", 
        "*://claude.ai/*",
        "*://*.deepseek.com/*",
        "*://*.doubao.com/*",
        "*://gemini.google.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}